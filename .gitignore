# Virtual Environment (highly recommended to ignore)
venv/
env/
.venv/

# Python caching
__pycache__/
*.pyc
*.pyo
*.pyd

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# Streamlit specific (local configurations)
.streamlit/config.toml
.streamlit/secrets.toml

# Operating System files
.DS_Store
Thumbs.db

# Large Data Files (Optional, but recommended if you downloaded heavy Kaggle datasets locally)
*.csv
*.pkl
*.pickle